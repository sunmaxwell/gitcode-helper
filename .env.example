# ===== GitCode 集成配置 =====

# GitCode API 根地址。
# GitCode v5 API:api.gitcode.com/api/v5(类 Gitee v5)。详见 https://docs.gitcode.com/docs/apis/
GITCODE_API_BASE=https://api.gitcode.com/api/v5

# GitCode Personal Access Token(需在 GitCode 个人设置 → 私人令牌 生成,授予 PR 评论权限)
# 仅服务端使用,绝不进前端。本地调试时留空可只做表单校验,不发评论。
GITCODE_TOKEN=

# ===== 服务配置 =====
# 监听端口
PORT=3000

# 允许的提交人:逗号分隔,留空表示不限制任何人。
# 建议填入真实可用提交人白名单,防止匿名滥用。
ALLOWED_SUBMITTERS=

# 防重复提交时间窗(分钟):同一 PR 在此窗口内仍有 pending/running 任务时,拒绝重复提交。
# 默认 10。覆盖 worker 轮询 + 网络抖动的处理时长即可。
DEDUP_WINDOW_MIN=10
